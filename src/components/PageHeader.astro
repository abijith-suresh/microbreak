---
import ThemeToggle from "@/components/ThemeToggle";

interface Props {
  title: string;
  tagline?: string;
}

const { title, tagline } = Astro.props;
---

<section class="px-5 md:px-10 pt-10 pb-8 md:pt-14 md:pb-10">
  <div class="flex items-start justify-between">
    <div>
      <h1
        class="font-display text-5xl md:text-6xl lg:text-7xl text-fg tracking-tight italic leading-[0.92]"
      >
        {title}
      </h1>
      {
        tagline && (
          <p class="mt-3 text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed max-w-xs">
            {tagline}
          </p>
        )
      }
      <div class="mt-4 h-px w-14 bg-accent opacity-40"></div>
    </div>
    <div class="mt-1">
      <ThemeToggle client:load />
    </div>
  </div>
</section>
