---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThemeToggle from "@/components/ThemeToggle";
import GameGrid from "@/components/GameGrid";
---

<BaseLayout>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="flex items-start justify-between px-5 md:px-10 pt-10 pb-8 md:pb-12">
      <div class="max-w-md">
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-fg tracking-tight italic">
          Microbreak
        </h1>
        <p class="mt-2 text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed">
          Puzzles for the gaps between builds
        </p>
        <div class="mt-3 h-px w-16 bg-accent opacity-40"></div>
      </div>
      <div class="mt-1">
        <ThemeToggle client:load />
      </div>
    </header>

    <!-- Game Grid -->
    <main class="flex-1 flex items-start justify-center pb-16 pt-2">
      <GameGrid client:load />
    </main>

    <!-- Footer -->
    <footer class="px-5 pb-8 text-center">
      <p class="text-xs text-fg-tertiary tracking-widest uppercase">
        No ads · No tracking · Just puzzles
      </p>
      <div class="mt-4 flex items-center justify-center gap-4 text-xs text-fg-tertiary">
        <a href="/about" class="hover:text-fg transition-colors"> About </a>
        <span class="opacity-30">·</span>
        <a
          href="https://github.com/abijith-suresh/microbreak"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 hover:text-fg transition-colors"
        >
          <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
          GitHub
        </a>
      </div>
    </footer>
  </div>
</BaseLayout>
