---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThemeToggle from "@/components/ThemeToggle";
import GameGrid from "@/components/GameGrid";
---

<BaseLayout>
  <div class="min-h-screen flex flex-col">
    <!-- Hero: brand name + tagline -->
    <section class="px-5 md:px-10 pt-10 pb-8 md:pt-14 md:pb-10">
      <div class="flex items-start justify-between">
        <div>
          <h1
            class="font-display text-5xl md:text-6xl lg:text-7xl text-fg tracking-tight italic leading-[0.92]"
          >
            Microbreak
          </h1>
          <p
            class="mt-3 text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed max-w-xs"
          >
            Puzzles for the gaps between builds
          </p>
          <div class="mt-4 h-px w-14 bg-accent opacity-40"></div>
        </div>
        <div class="mt-1">
          <ThemeToggle client:load />
        </div>
      </div>
    </section>

    <!-- Game grid with animated previews -->
    <main class="flex-1 flex items-start justify-center pb-16 pt-2">
      <GameGrid client:load />
    </main>

    <!-- Footer -->
    <footer class="px-5 md:px-10 pb-10">
      <div class="h-px bg-border mb-6"></div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <p class="text-xs text-fg-tertiary tracking-widest uppercase">
          No ads · No tracking · Just puzzles
        </p>
        <div class="flex items-center gap-4 text-xs text-fg-tertiary">
          <a href="/about" class="hover:text-fg transition-colors">About</a>
          <span class="opacity-30">·</span>
          <a
            href="https://github.com/abijith-suresh/microbreak"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-fg transition-colors"
          >
            GitHub
          </a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
