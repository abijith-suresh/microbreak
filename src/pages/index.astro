---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThemeToggle from "@/components/ThemeToggle";
import GameGrid from "@/components/GameGrid";
---

<BaseLayout>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="flex items-center justify-between px-5 md:px-8 pt-8 pb-6 md:pb-8">
      <div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-[var(--color-text-primary)] tracking-tight">
          Microbreak
        </h1>
        <p class="mt-1 text-sm md:text-base text-[var(--color-text-secondary)] font-light tracking-wide">
          Puzzles for the gaps between builds
        </p>
      </div>
      <ThemeToggle client:load />
    </header>

    <!-- Game Grid -->
    <main class="flex-1 flex items-start justify-center pb-12 pt-4">
      <GameGrid client:load />
    </main>

    <!-- Footer nudge -->
    <footer class="px-5 pb-6 text-center">
      <p class="text-xs text-[var(--color-text-tertiary)]">
        No ads · No tracking · Just puzzles
      </p>
    </footer>
  </div>
</BaseLayout>
