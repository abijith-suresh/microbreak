---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThemeToggle from "@/components/ThemeToggle";
import GameGrid from "@/components/GameGrid";
---

<BaseLayout>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="flex items-start justify-between px-5 md:px-10 pt-10 pb-8 md:pb-12">
      <div class="max-w-md">
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-fg tracking-tight italic">
          Microbreak
        </h1>
        <p class="mt-2 text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed">
          Puzzles for the gaps between builds
        </p>
        <div class="mt-3 h-px w-16 bg-accent opacity-40"></div>
      </div>
      <div class="mt-1">
        <ThemeToggle client:load />
      </div>
    </header>

    <!-- Game Grid -->
    <main class="flex-1 flex items-start justify-center pb-16 pt-2">
      <GameGrid client:load />
    </main>

    <!-- Footer -->
    <footer class="px-5 pb-8 text-center">
      <p class="text-xs text-fg-tertiary tracking-widest uppercase">
        No ads · No tracking · Just puzzles
      </p>
    </footer>
  </div>
</BaseLayout>
