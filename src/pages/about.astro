---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buttonVariants } from "@/components/ui/Button";
import ThemeToggle from "@/components/ThemeToggle";
---

<BaseLayout
  title="About — Microbreak"
  description="Microbreak is a collection of short, non-addictive puzzles designed for the gaps between builds — no ads, no tracking, no dark patterns."
>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="flex items-start justify-between px-5 md:px-10 pt-10 pb-8 md:pb-12">
      <div class="max-w-md">
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-fg tracking-tight italic">
          Microbreak
        </h1>
        <div class="mt-3 h-px w-16 bg-accent opacity-40"></div>
      </div>
      <div class="mt-1">
        <ThemeToggle client:load />
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1 flex flex-col items-center px-5 pb-24">
      <article class="w-full max-w-prose">
        <h2 class="font-display text-3xl md:text-4xl text-fg tracking-tight italic">
          Why Microbreak?
        </h2>
        <div class="mt-3 h-px w-12 bg-accent opacity-40"></div>

        <div
          class="mt-8 space-y-5 text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed"
        >
          <p>
            Builds, tests, deploys — software development is full of short waiting periods. Too
            short to start something new, too long to just stare at a progress bar.
          </p>
          <p>
            Microbreak is a collection of puzzles designed specifically for those gaps. Each game
            takes seconds to learn and minutes to play — just enough to give your brain a reset
            without pulling you into a deep focus session.
          </p>
          <p>
            There are no ads. No tracking. No notifications. No streaks, no leaderboards, no dark
            patterns engineered to keep you playing. When you close the tab, the game is over — and
            that's intentional.
          </p>
          <p>
            Puzzles include Sudoku, Wordle, Minesweeper, and 2048 — all rendered entirely in the
            browser with no external data calls. Your progress is saved locally, and nothing leaves
            your device.
          </p>
        </div>

        <div class="mt-10">
          <a href="/" class={buttonVariants({ variant: "primary" })}>
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path>
            </svg>
            Back to puzzles
          </a>
        </div>
      </article>
    </main>

    <!-- Footer -->
    <footer class="px-5 pb-8 text-center">
      <p class="text-xs text-fg-tertiary tracking-widest uppercase">
        No ads · No tracking · Just puzzles
      </p>
      <div class="mt-4 flex items-center justify-center gap-4 text-xs text-fg-tertiary">
        <a href="/" class="hover:text-fg transition-colors"> Home </a>
        <span class="opacity-30">·</span>
        <a
          href="https://github.com/abijith-suresh/microbreak"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-fg transition-colors"
        >
          GitHub
        </a>
      </div>
    </footer>
  </div>
</BaseLayout>
