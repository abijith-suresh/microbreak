---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import PageFooter from "@/components/PageFooter.astro";
import { buttonVariants } from "@/components/ui/Button";
import { House } from "@lucide/astro";
---

<BaseLayout
  title="About — Microbreak"
  description="Microbreak is a collection of short, non-addictive puzzles designed for the gaps between builds — no ads, no tracking, no dark patterns."
>
  <div class="min-h-screen flex flex-col">
    <PageHeader title="About" />

    <main class="flex-1 flex flex-col items-center px-5 md:px-10 pb-16">
      <article class="w-full max-w-prose">
        <div class="space-y-5 text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed">
          <p>
            Microbreak is built for the in-between moments of software development: waiting for
            builds, test suites, deployments, or package installs to finish.
          </p>
          <p>
            Those small gaps are awkward. They're too short to start meaningful work, but long
            enough to break your flow if you drift too far. Microbreak fills that space with quick,
            low-commitment puzzles that reset your brain without hijacking your attention.
          </p>
          <p>
            The platform offers familiar games like Sudoku, Wordle, Minesweeper, and 2048, each
            designed to load instantly, play smoothly, and end cleanly. You can jump in for a minute
            or two, then get back to work without feeling trapped in an endless session.
          </p>
          <p>Microbreak is intentionally simple:</p>
          <ul class="list-none pl-0 space-y-1.5">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5 select-none">–</span>
              <span>No ads</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5 select-none">–</span>
              <span>No tracking</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5 select-none">–</span>
              <span>No notifications</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5 select-none">–</span>
              <span>No streak systems</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5 select-none">–</span>
              <span>No leaderboards</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5 select-none">–</span>
              <span>No engagement traps</span>
            </li>
          </ul>
          <p>
            Everything runs entirely in your browser. There are no external API calls, no
            unnecessary accounts, and no data collection. Your progress stays on your device, saved
            locally.
          </p>
          <p>Close the tab, and you're done.</p>
          <p>
            Microbreak respects your time, your focus, and your privacy. It exists for one purpose:
            giving developers and other knowledge workers a better way to spend the small waiting
            periods built into modern work.
          </p>
        </div>

        <div class="mt-10">
          <a href="/" class={buttonVariants({ variant: "primary" })}>
            <House size={16} />
            Back to puzzles
          </a>
        </div>
      </article>
    </main>

    <PageFooter currentPage="about" />
  </div>
</BaseLayout>
