---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import PageFooter from "@/components/PageFooter.astro";
import { buttonVariants } from "@/components/ui/Button";
import { House } from "@lucide/astro";
---

<BaseLayout
  title="404 — Page not found · Microbreak"
  description="This page has wandered off — maybe it's taking a break, too."
>
  <div class="min-h-screen flex flex-col">
    <PageHeader title="404" />

    <main class="flex-1 flex flex-col items-center justify-center px-5 pb-24 text-center">
      <p class="font-display text-2xl md:text-3xl text-fg tracking-tight italic">Page not found</p>
      <p class="mt-3 max-w-md text-sm md:text-base text-fg-secondary tracking-wide leading-relaxed">
        This page has wandered off — maybe it's taking a break, too.
      </p>
      <div class="mt-8">
        <a href="/" class={buttonVariants({ variant: "primary" })}>
          <House size={16} />
          Back to home
        </a>
      </div>
    </main>

    <PageFooter />
  </div>
</BaseLayout>
