    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
