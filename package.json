{
  "name": "microbreak",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "version": "0.0.13",
  "license": "MIT",
  "homepage": "https://github.com/abijith-suresh/microbreak#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abijith-suresh/microbreak.git"
  },
  "bugs": {
    "url": "https://github.com/abijith-suresh/microbreak/issues"
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "bun run type-check && bun run lint && bun run format:check && bun run test && bun run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/solid-js": "^7.0.1",
    "@lucide/astro": "^1.24.0",
    "@tailwindcss/vite": "^4.3.3",
